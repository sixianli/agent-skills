{
  "repository_checks": [
    {
      "name": "validate-all-py-compile",
      "command": [
        "python3",
        "-m",
        "py_compile",
        "scripts/validate_all.py"
      ]
    },
    {
      "name": "validate-all-ruff",
      "command": [
        "uv",
        "run",
        "--with",
        "ruff",
        "ruff",
        "check",
        "scripts/validate_all.py"
      ]
    }
  ],
  "skills": [
    {
      "name": "opencode-delegation",
      "package_dir": "codex-delegate-to-opencode-skill",
      "readme": "codex-delegate-to-opencode-skill/README.md",
      "skill_dir": "codex-delegate-to-opencode-skill/opencode-delegation",
      "description": "Delegate coding work to local OpenCode while Codex supervises, reviews, and verifies.",
      "implicit_invocation": true,
      "has_tests": false,
      "checks": []
    },
    {
      "name": "document-governance",
      "package_dir": "document-governance",
      "readme": "document-governance/SKILL.md",
      "skill_dir": "document-governance",
      "description": "Govern project documentation, durable Ideas and Backlog, and optional root current.md Working State.",
      "implicit_invocation": true,
      "has_tests": true,
      "checks": [
        {
          "name": "py-compile",
          "command": [
            "python3",
            "-m",
            "py_compile",
            "document-governance/scripts/archive_doc.py",
            "document-governance/scripts/tracking.py",
            "document-governance/scripts/validate_docs.py",
            "document-governance/scripts/working_state.py"
          ]
        },
        {
          "name": "unittest",
          "command": [
            "python3",
            "-m",
            "unittest",
            "discover",
            "-s",
            "document-governance/tests",
            "-v"
          ]
        },
        {
          "name": "ruff",
          "command": [
            "uv",
            "run",
            "--with",
            "ruff",
            "ruff",
            "check",
            "document-governance/scripts",
            "document-governance/tests"
          ]
        }
      ]
    }
  ]
}
